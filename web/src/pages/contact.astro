---
import BaseLayout from '../layouts/BaseLayout.astro';

const formEndpoint = 'https://formspree.io/f/xbldlbwk';
const base = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';
const submitted = new URL(Astro.request.url).searchParams.get('submitted');
---
<BaseLayout title="Contact – Portfolio" current="contact">
  <section class="px-margin-mobile md:px-gutter py-16 lg:py-24">
    <div class="max-w-container mx-auto">
      <!-- Hero -->
      <div class="mb-12">
        <h1 class="font-sans text-headline-lg-mobile md:text-headline-lg text-on-surface mb-2">Get in Touch</h1>
        <p class="text-on-surface-variant font-sans text-body-sm max-w-md">
          Whether you're looking for technical leadership, architectural consultation, or just want to discuss the future of engineering management.
        </p>
      </div>

      <!-- Availability indicator -->
      <div class="flex items-center gap-2 mb-10">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="font-mono text-label-code text-on-surface">Available for projects</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Form -->
        <div>
          {submitted === '1' && (
            <div class="mb-6 p-4 border border-emerald-500/30 bg-emerald-500/5" role="status">
              <p class="font-mono text-label-code text-emerald-400">MESSAGE_SENT_SUCCESSFULLY</p>
              <p class="font-sans text-body-sm text-on-surface-variant mt-1">Thanks — your message was sent. I'll respond as soon as I can.</p>
            </div>
          )}

          <form
            method="POST"
            action={formEndpoint}
            accept-charset="UTF-8"
            class="space-y-6"
            id="contact-form"
          >
            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true">
              <label>
                Don't fill this out if you're human
                <input name="_honeypot" type="text" />
              </label>
            </div>
            <input type="hidden" name="_redirect" value={`${base}/contact?submitted=1`} />

            <!-- Name -->
            <div class="flex flex-col gap-2">
              <label class="font-label-caps text-label-caps text-on-surface-variant transition-colors" for="name">NAME</label>
              <input
                id="name"
                name="name"
                required
                placeholder="John Doe"
                class="bg-surface-container-lowest border border-outline-variant/30 px-4 py-3 font-mono text-label-code text-on-surface placeholder:text-on-surface-variant/30 transition-all focus:outline-none focus:border-primary"
                style="box-shadow: 0 0 0 0px rgba(201, 198, 197, 0.2);"
              />
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-2">
              <label class="font-label-caps text-label-caps text-on-surface-variant transition-colors" for="email">EMAIL</label>
              <input
                id="email"
                type="email"
                name="email"
                required
                placeholder="john@example.com"
                class="bg-surface-container-lowest border border-outline-variant/30 px-4 py-3 font-mono text-label-code text-on-surface placeholder:text-on-surface-variant/30 transition-all focus:outline-none focus:border-primary"
              />
            </div>

            <!-- Message -->
            <div class="flex flex-col gap-2">
              <label class="font-label-caps text-label-caps text-on-surface-variant transition-colors" for="message">MESSAGE</label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell me about your project..."
                class="bg-surface-container-lowest border border-outline-variant/30 px-4 py-3 font-sans text-body-md text-on-surface placeholder:text-on-surface-variant/30 transition-all resize-none focus:outline-none focus:border-primary"
              ></textarea>
            </div>

            <!-- Privacy consent -->
            <div class="flex items-start gap-3">
              <input
                id="consent"
                type="checkbox"
                required
                class="mt-0.5 accent-primary"
              />
              <label for="consent" class="font-sans text-body-sm text-on-surface-variant/70">
                I consent to you storing my name and email for the purposes of responding to this enquiry. See privacy note below.
              </label>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="bg-off-white text-off-black px-8 py-3 font-label-caps text-label-caps transition-all active:scale-95 hover:bg-white"
            >
              SEND_MESSAGE
            </button>
          </form>

          <!-- Mailto fallback -->
          <p class="mt-8 font-sans text-body-sm text-on-surface-variant/60">
            Prefer email?{' '}
            <a href="mailto:you@example.com?subject=Portfolio%20enquiry" class="underline hover:text-on-surface transition-colors">
              you@example.com
            </a>
          </p>
        </div>

        <!-- Sidebar info -->
        <div class="lg:pt-2">
          <div class="glass-card p-6 flex flex-col gap-5">
            <div>
              <p class="font-mono text-[10px] text-on-surface-variant/40 uppercase tracking-widest mb-1">Response Time</p>
              <p class="font-sans text-body-sm text-on-surface">Typically within 24–48 hours</p>
            </div>
            <div>
              <p class="font-mono text-[10px] text-on-surface-variant/40 uppercase tracking-widest mb-1">Location</p>
              <p class="font-sans text-body-sm text-on-surface">London, UK (Remote-friendly)</p>
            </div>
            <div>
              <p class="font-mono text-[10px] text-on-surface-variant/40 uppercase tracking-widest mb-1">Privacy</p>
              <p class="font-sans text-body-sm text-on-surface-variant/70">
                Your data is submitted via Formspree and will only be used to respond to your enquiry. It will not be shared or used for marketing.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Focus ring effect on input groups
  document.querySelectorAll('input:focus-visible, textarea:focus-visible').forEach((el) => {
    el.addEventListener('focus', () => {
      el.style.boxShadow = '0 0 0 1px rgba(201, 198, 197, 0.2)';
    });
    el.addEventListener('blur', () => {
      el.style.boxShadow = '0 0 0 0px rgba(201, 198, 197, 0.2)';
    });
  });
</script>
