<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Decap CMS</title>
    <script>
      window.CMS_MANUAL_INIT = true;
    </script>
  </head>
  <body>
    <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
    <script>
      (function initDecap() {
        const url = new URL(window.location.href);
        const base = '/ppm';
        const configUrl = `${window.location.origin}${base}/admin/config.yml`;

        if (!url.searchParams.get('config')) {
          url.searchParams.set('config', configUrl);
          window.location.replace(url.toString());
          return;
        }

        window.CMS.init({
          config: {
            load_config_file: true,
            config_url: url.searchParams.get('config') || configUrl,
            backend: {
              name: 'github',
              repo: 'dickytunes/ppm',
              branch: 'master',
              auth_type: 'pkce',
              app_id: 'Ov23lid7cVp43gNV82f8',
            },
            media_folder: 'web/public/uploads',
            public_folder: '/ppm/uploads',
          },
        });
      })();
    </script>
  </body>
</html>
