---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCaseStudies } from '../../lib/content';

const caseStudies = await getCaseStudies();
const base = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';
---

<BaseLayout title="Case Studies – Portfolio" current="portfolio">
  <section class="px-margin-mobile md:px-gutter py-16 lg:py-24">
    <div class="max-w-container mx-auto flex flex-col gap-8">
      <!-- Header -->
      <div class="flex flex-col gap-2 relative">
        <div class="absolute -top-12 -left-12 w-64 h-64 bg-primary/5 rounded-full blur-[80px] pointer-events-none"></div>
        <h1 class="font-sans text-headline-lg-mobile md:text-headline-lg text-on-surface">Case Studies</h1>
        <p class="text-on-surface-variant font-sans text-body-sm max-w-md">
          A deep dive into high-impact engineering leadership and architectural transformations.
        </p>
      </div>

      {caseStudies.length === 0 && (
        <p class="text-on-surface-variant font-mono text-label-code mt-4">
          Content to come – case studies will be loaded from Decap.
        </p>
      )}

      <!-- Case Study Cards -->
      {caseStudies.length > 0 && (
        <div class="flex flex-col gap-4">
          {caseStudies.map((study) => (
            <a
              href={`${base}/case-studies/${study.slug}`}
              class="glass-card p-6 flex flex-col gap-4 group active:scale-[0.98] transition-transform duration-200"
            >
              <div class="flex justify-between items-start">
                <span class="font-mono text-[11px] text-primary/80 uppercase tracking-widest">{study.role}</span>
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-on-surface-variant/40 group-hover:text-primary transition-colors">
                  <path d="M7 17L17 7M17 7H7M17 7V17"/>
                </svg>
              </div>
              <div class="flex flex-col gap-1">
                <h2 class="font-sans text-headline-lg-mobile md:text-[28px] md:leading-tight text-on-surface leading-tight">{study.title}</h2>
                <p class="font-sans text-body-sm text-on-surface-variant">{study.summary}</p>
              </div>
              {study.technologies.length > 0 && (
                <div class="flex flex-wrap gap-2 my-2">
                  {study.technologies.map((tech) => (
                    <span class="bg-surface-container-high text-on-surface px-2 py-1 font-mono text-[10px] rounded">{tech}</span>
                  ))}
                </div>
              )}
              <div class="pt-4 border-t border-outline-variant/20 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-on-surface-variant">
                    <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"/>
                  </svg>
                  <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">{study.role}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
