---
import { getCompanies, getSettings } from '../lib/content';

import '../styles/global.css';

interface Props {
  title?: string;
  current?: 'portfolio' | 'philosophy' | 'stack' | 'contact';
  hideSidebar?: boolean;
}

const { title = 'Portfolio', current = 'portfolio', hideSidebar = false } = Astro.props as Props;

const base = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';
const companies = await getCompanies();
const settings = await getSettings();
const socialLinks = settings?.socialLinks || [];

const navItems = [
  { label: 'Case Studies', icon: 'code', route: '/', key: 'portfolio' as const },
  { label: 'Philosophy', icon: 'psychology', route: '/philosophy', key: 'philosophy' as const },
  { label: 'Stack', icon: 'terminal', route: '/stack', key: 'stack' as const },
  { label: 'Contact', icon: 'mail', route: '/contact', key: 'contact' as const },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=geist@400,500,600,700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-surface text-on-surface font-sans text-body-md overflow-x-hidden">

    <!-- ===== Mobile Top Bar ===== -->
    {!hideSidebar && (
    <header class="fixed top-0 w-full z-50 h-16 bg-surface border-b border-outline-variant/30 flex justify-between items-center px-margin-mobile md:px-gutter lg:hidden">
      <div class="flex items-center gap-3">
        <button id="drawer-open" class="cursor-pointer active:opacity-70 p-2 -ml-2" aria-label="Open navigation">
          <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary">
            <path d="M3 6h18M3 12h18M3 18h18"/>
          </svg>
        </button>
        <span class="font-mono text-label-code tracking-tighter text-on-surface">ENGINEER_MANAGER</span>
      </div>
      <div class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center border border-outline-variant/30 overflow-hidden">
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-on-surface-variant">
          <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2Z"/>
          <path d="M12 6a4 4 0 0 0-4 4c0 1.5.8 2.8 2 3.5V16h4v-2.5c1.2-.7 2-2 2-3.5a4 4 0 0 0-4-4Z"/>
        </svg>
      </div>
    </header>
    )}

    <!-- ===== Navigation Drawer Overlay ===== -->
    {!hideSidebar && (
    <div id="drawer-overlay" class="fixed inset-0 bg-black/60 z-[55] hidden backdrop-blur-sm transition-opacity duration-300 lg:hidden" aria-hidden="true"></div>

    <!-- ===== Sidebar / Drawer ===== -->
    <aside
      id="nav-drawer"
      class="fixed inset-y-0 left-0 z-[60] flex flex-col h-full w-[280px] bg-surface-container-low border-r border-outline-variant/20 shadow-2xl transition-transform duration-500 ease-in-out -translate-x-full lg:translate-x-0"
      aria-label="Primary navigation"
    >
      <!-- Drawer header (mobile only) -->
      <div class="p-margin-mobile h-16 flex items-center justify-between lg:hidden">
        <span class="font-mono text-label-code text-primary">NAVIGATION</span>
        <button id="drawer-close" class="cursor-pointer active:opacity-70" aria-label="Close navigation">
          <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-on-surface-variant">
            <path d="M6 6l12 12M18 6 6 18"/>
          </svg>
        </button>
      </div>

      <!-- Desktop branding -->
      <div class="hidden lg:flex items-center gap-2 px-6 pt-8 pb-6">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="font-mono text-label-code tracking-tighter text-on-surface">ENGINEER_MANAGER</span>
      </div>

      <!-- Nav links -->
      <nav class="flex-1 flex flex-col gap-1 px-0 mt-2 lg:mt-0">
        {navItems.map((item) => {
          const isActive = current === item.key;
          return (
            <a
              href={`${base}${item.route}`}
              aria-current={isActive ? 'page' : undefined}
              class={`flex items-center gap-4 px-6 py-4 transition-all duration-300 ${
                isActive
                  ? 'border-l-2 border-primary bg-secondary-container/10 text-on-surface font-semibold'
                  : 'border-l-2 border-transparent text-on-secondary-container/60 hover:text-on-surface hover:bg-surface-container-high'
              }`}
            >
              <!-- Icons -->
              {item.icon === 'code' && (
                <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={isActive ? 'text-primary' : ''}>
                  <path d="m16 18 6-6-6-6M8 6l-6 6 6 6"/>
                </svg>
              )}
              {item.icon === 'psychology' && (
                <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={isActive ? 'text-primary' : ''}>
                  <path d="M9.5 2A2.5 2.5 0 0 0 7 4.5V15c0 1.5 1 2 1 2h2v2l2-2h3c1 0 2-.5 2-2V4.5A2.5 2.5 0 0 0 14.5 2h-5Z"/>
                  <path d="M10 7h4M10 10h3"/>
                </svg>
              )}
              {item.icon === 'terminal' && (
                <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={isActive ? 'text-primary' : ''}>
                  <path d="m4 17 6-6-6-6M12 19h8"/>
                </svg>
              )}
              {item.icon === 'mail' && (
                <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={isActive ? 'text-primary' : ''}>
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              )}
              <span class="font-label-caps text-label-caps">{item.label}</span>
            </a>
          );
        })}
      </nav>

      <!-- Sidebar footer -->
      <div class="p-6 border-t border-outline-variant/10">
        <p class="font-mono text-[10px] text-on-surface-variant/40 leading-relaxed uppercase">
          Architect_OS // V2.4.0<br/>
          Stable Build: 2024.11
        </p>
      </div>
    </aside>
    )}

    <!-- ===== Main Content Area ===== -->
    <div class={`flex-1 flex flex-col ${hideSidebar ? '' : 'lg:ml-[280px]'}`}>
      <main class={`flex-1 ${hideSidebar ? '' : 'pt-16 lg:pt-0'}`}>
        <slot />
      </main>

      <!-- Sub-footer: Company logos -->
      {companies.length > 0 && (
        <div class="border-t border-outline-variant/20 bg-surface/50 py-10">
          <div class="max-w-container mx-auto px-margin-mobile md:px-gutter">
            <p class="font-label-caps text-label-caps text-on-surface-variant/60 uppercase tracking-widest mb-6">Companies I've worked with</p>
            <div class="flex flex-wrap gap-8 items-center">
              {companies.map((company) => (
                <a
                  href={company.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="opacity-50 hover:opacity-80 transition-opacity"
                  aria-label={company.companyName}
                >
                  <img src={`${base}${company.logo}`} alt={company.companyName} class="h-8 w-auto" />
                </a>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- Main footer -->
      <footer class="border-t border-outline-variant/20 bg-surface-container-lowest/50 py-6">
        <div class="max-w-container mx-auto px-margin-mobile md:px-gutter flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <p class="font-mono text-[11px] text-on-surface-variant/40">© {new Date().getFullYear()}. All rights reserved.</p>
          <div class="flex gap-5">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="font-label-caps text-label-caps text-on-surface-variant/50 hover:text-on-surface transition-colors"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </footer>
    </div>

    {!hideSidebar && (
    <script>
      const drawer = document.getElementById('nav-drawer');
      const overlay = document.getElementById('drawer-overlay');
      const openBtn = document.getElementById('drawer-open');
      const closeBtn = document.getElementById('drawer-close');

      function openDrawer() {
        drawer?.classList.remove('-translate-x-full');
        overlay?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        drawer?.classList.add('-translate-x-full');
        overlay?.classList.add('hidden');
        document.body.style.overflow = '';
      }

      openBtn?.addEventListener('click', openDrawer);
      closeBtn?.addEventListener('click', closeDrawer);
      overlay?.addEventListener('click', closeDrawer);

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !drawer?.classList.contains('-translate-x-full')) {
          closeDrawer();
        }
      });
    </script>
    )}

  </body>
</html>
